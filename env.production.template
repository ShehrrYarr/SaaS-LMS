# ============================================================
# Production .env template for Namecheap shared hosting.
# Copy this into a file named .env on the SERVER (never commit
# the real .env). Fill every <PLACEHOLDER>.
# ============================================================

APP_NAME="Lab Manager"
APP_ENV=production
# CRITICAL: copy APP_KEY from your LOCAL .env — do NOT run key:generate
# on the server. This key decrypts all stored lab/branch/superadmin
# passwords; a different key makes them unreadable.
APP_KEY=<COPY_FROM_LOCAL_.ENV>
APP_DEBUG=false
APP_URL=https://<app.yourdomain.com>

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=daily
LOG_LEVEL=error

# cPanel MySQL — names are prefixed with your cPanel username,
# e.g. user_lms / user_lmsdb
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=<CPANEL_DB_NAME>
DB_USERNAME=<CPANEL_DB_USER>
DB_PASSWORD=<CPANEL_DB_PASSWORD>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Jobs (report-ready + patient-credential emails) run from the
# queue table via the cron job described in DEPLOYMENT.md.
QUEUE_CONNECTION=database

CACHE_STORE=database

# Platform-level mail (rarely used — labs configure their own SMTP
# in Settings). "log" writes would-be emails to storage/logs.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@<yourdomain.com>"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
